# ==============================================
# 1. Import basic libraries
# ==============================================
import wrds
import pandas as pd
import matplotlib.pyplot as plt
from sqlalchemy import text

# ==============================================
# 2. Connect to WRDS and get stock data
# ==============================================
# Connect to WRDS database
db = wrds.Connection()

# Simple SQL query to get AAPL and MSFT price data (2023-2026)
sql_query = """
SELECT date, ticker, prc
FROM crsp.dsf
WHERE ticker IN ('AAPL', 'MSFT')
AND date >= '2023-01-01'
"""

# Execute query (fixed for your Python environment)
with db.engine.connect() as conn:
    df = pd.read_sql_query(text(sql_query), conn, parse_dates=["date"])

# Close WRDS connection
db.close()

# ==============================================
# 3. Clean the data
# ==============================================
# Fix price (CRSP uses negative values for split-adjusted prices)
df['adj_price'] = df['prc'].abs()
# Remove any missing values
df = df.dropna()

# Show first 5 rows to check data
print("First 5 rows of the dataset:")
print(df.head())

# ==============================================
# 4. Prepare data for plotting
# ==============================================
# Pivot data to make AAPL and MSFT as separate columns
price_pivot = df.pivot(index='date', columns='ticker', values='adj_price')

# ==============================================
# 5. Create simple price trend chart
# ==============================================
plt.figure(figsize=(10, 5))
price_pivot.plot(ax=plt.gca())
plt.title('AAPL vs MSFT Stock Price (2023-2026)')
plt.xlabel('Date')
plt.ylabel('Adjusted Price (USD)')
plt.legend(title='Stock Ticker')
plt.tight_layout()
plt.show()

# ==============================================
# 6. Basic summary statistics
# ==============================================
print("\nPrice Summary Statistics:")
print(price_pivot.describe())
